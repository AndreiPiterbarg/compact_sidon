        exact Finset.sum_le_sum fun i _ => by split_ifs <;> linarith [ show 0 ≤ bin_masses f n i from bin_masses_nonneg n f hf_nonneg i ] ;
      exact h_discrete_cum_nonneg _ _ ( by omega )

lemma discrete_cum_global_mono (f : ℝ → ℝ) (n m : ℕ) (hf_nonneg : ∀ x, 0 ≤ f x) :
    Monotone (discrete_cum_global f n m) := by
  -- The cumulative mass function is non-decreasing because each step adds a non-negative bin mass.
  have h_cumulative_mass_nonneg : Monotone (cumulative_mass f n) := by
    -- Since the bin masses are non-negative, adding more terms to the sum can't decrease the total. Therefore, the cumulative mass function is monotone.
    intros k l hkl
    simp [cumulative_mass, hkl];
    -- Since $k \leq l$, the set of indices where $j < k$ is a subset of the set where $j < l$. Therefore, the sum over the smaller set is less than or equal to the sum over the larger set.
    apply Finset.sum_le_sum; intro j _; split_ifs <;> norm_num ; linarith [hkl];
    exact?
  generalize_proofs at *; (
  intro k l hkl; simp [discrete_cum_global, h_cumulative_mass_nonneg hkl];
  rw [ ← Int.ofNat_le, Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr <| mul_nonneg ( show 0 ≤ cumulative_mass f n k from ?_ ) <| Nat.cast_nonneg m ), Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr <| mul_nonneg ( show 0 ≤ cumulative_mass f n l from ?_ ) <| Nat.cast_nonneg m ) ] ; exact Int.floor_mono <| mul_le_mul_of_nonneg_right ( h_cumulative_mass_nonneg hkl ) <| Nat.cast_nonneg m ; all_goals exact cumulative_mass_nonneg f n _ hf_nonneg;)

noncomputable def epsilon_error (f : ℝ → ℝ) (n m : ℕ) (i : ℕ) : ℝ :=
  (discrete_cum_global f n m i : ℝ) / m - cumulative_mass f n i

lemma c_sub_mu_eq_epsilon_diff (n m : ℕ) (hn : n > 0) (hm : m > 0) (f : ℝ → ℝ)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1)
    (hf_nonneg : ∀ x, 0 ≤ f x)
    (c : Fin (2 * n) → ℕ) (hc : canonical_discretization f n m = c)
    (i : Fin (2 * n)) :
    (c i : ℝ) / m - bin_masses f n i =
      if i.1 < 2 * n - 1 then
        epsilon_error f n m (i.1 + 1) - epsilon_error f n m i.1
      else
        - epsilon_error f n m i.1 := by
  split_ifs <;> simp_all +decide [ epsilon_error ];
  · rw [ ← hc ];
    unfold canonical_discretization ; ring;
    rw [ if_pos ];
    · rw [ Nat.cast_sub ] <;> norm_num [ discrete_cum_global, cumulative_mass ] ; ring;
      · rw [ show ( ∑ j : Fin ( 2 * n ), bin_masses f n j ) = 1 from ?_ ] ; ring;
        · rw [ show ( ∑ x : Fin ( 2 * n ), if ( x : ℕ ) < 1 + ( i : ℕ ) then bin_masses f n x else 0 ) = ( ∑ x : Fin ( 2 * n ), if x < i then bin_masses f n x else 0 ) + bin_masses f n i from ?_ ] ; ring;
          rw [ Finset.sum_eq_sum_diff_singleton_add ( Finset.mem_univ i ) ] ; simp +decide [ add_comm, Finset.sum_ite ] ; ring;
          refine' Finset.sum_bij ( fun x hx => x ) _ _ _ _ <;> simp_all +decide [ Fin.ext_iff ];
          · exact fun a ha₁ ha₂ => lt_of_le_of_ne ( Nat.le_of_lt_succ <| by linarith ) ( by simpa [ Fin.ext_iff ] using ha₁ ) ;
          · exact fun b hb => ⟨ b, ⟨ ne_of_lt hb, by linarith [ show ( b : ℕ ) < i from hb ] ⟩, rfl ⟩;
        · convert sum_bin_masses_eq_one n hn f ( show Function.support f ⊆ Set.Ioo ( -1 / 4 ) ( 1 / 4 ) from fun x hx => ⟨ by linarith [ hf_supp x hx ], by linarith [ hf_supp x hx ] ⟩ ) hf_int using 1;
      · rw [ show ( ∑ x : Fin ( 2 * n ), if ( x : ℕ ) < 1 + ( i : ℕ ) then bin_masses f n x else 0 ) = ( ∑ x : Fin ( 2 * n ), if x < i then bin_masses f n x else 0 ) + bin_masses f n i from ?_ ] ; ring_nf ;
        · rw [ ← Int.ofNat_le, Int.natAbs_of_nonneg, Int.natAbs_of_nonneg ] <;> norm_num [ Int.floor_nonneg ];
          · exact Int.floor_mono <| le_add_of_nonneg_right <| mul_nonneg ( mul_nonneg ( inv_nonneg.2 <| Finset.sum_nonneg fun _ _ => bin_masses_nonneg n f hf_nonneg _ ) <| Nat.cast_nonneg _ ) <| bin_masses_nonneg n f hf_nonneg _;
          · refine' add_nonneg _ _ <;> refine' mul_nonneg _ _;
            · exact mul_nonneg ( inv_nonneg.2 ( Finset.sum_nonneg fun _ _ => bin_masses_nonneg n f hf_nonneg _ ) ) ( Nat.cast_nonneg _ );
            · exact Finset.sum_nonneg fun _ _ => by split_ifs <;> [ exact bin_masses_nonneg n f hf_nonneg _ ; exact le_rfl ] ;
            · exact mul_nonneg ( inv_nonneg.2 ( Finset.sum_nonneg fun _ _ => bin_masses_nonneg n f hf_nonneg _ ) ) ( Nat.cast_nonneg _ );
            · exact?;
          · exact mul_nonneg ( mul_nonneg ( inv_nonneg.2 ( Finset.sum_nonneg fun _ _ => bin_masses_nonneg n f hf_nonneg _ ) ) ( Nat.cast_nonneg _ ) ) ( Finset.sum_nonneg fun _ _ => by split_ifs <;> linarith [ bin_masses_nonneg n f hf_nonneg ‹_› ] );
        · rw [ Finset.sum_eq_sum_diff_singleton_add ( Finset.mem_univ i ) ] ; simp +decide [ add_comm, Finset.sum_ite ] ; ring;
          refine' Finset.sum_bij ( fun x hx => x ) _ _ _ _ <;> simp_all +decide [ Fin.ext_iff ];
          · exact fun a ha₁ ha₂ => lt_of_le_of_ne ( Nat.le_of_lt_succ <| by linarith ) ( by simpa [ Fin.ext_iff ] using ha₁ ) ;
          · exact fun b hb => ⟨ b, ⟨ ne_of_lt hb, by linarith [ show ( b : ℕ ) < i from hb ] ⟩, rfl ⟩;
    · omega;
  · -- By definition of $c$, we know that $c i = m - discrete_cum_global f n m (2 * n - 1)$.
    have h_ci : c i = m - discrete_cum_global f n m (2 * n - 1) := by
      rw [ ← hc ];
      unfold canonical_discretization;
      norm_num [ show ( i : ℕ ) = 2 * n - 1 by omega ];
      rw [ if_neg ( by omega ) ];
      unfold discrete_cum_global; norm_num [ cumulative_mass ] ;
      rw [ show ( ∑ j : Fin ( 2 * n ), bin_masses f n j ) = 1 from ?_ ] ; norm_num;
      convert sum_bin_masses_eq_one n hn f _ _ ; aesop;
      exact hf_int;
    -- Substitute the definition of `cumulative_mass` into the equation.
    have h_cumulative_mass : cumulative_mass f n i = 1 - bin_masses f n i := by
      have h_cumulative_mass : ∑ j : Fin (2 * n), bin_masses f n j = 1 := by
        convert sum_bin_masses_eq_one n hn f ( show Function.support f ⊆ Set.Ioo ( -1 / 4 ) ( 1 / 4 ) from fun x hx => ⟨ by linarith [ hf_supp x hx ], by linarith [ hf_supp x hx ] ⟩ ) hf_int using 1;
      rw [ ← h_cumulative_mass, show cumulative_mass f n ( i : ℕ ) = ∑ j : Fin ( 2 * n ), if j.1 < i.val then bin_masses f n j else 0 from rfl, Finset.sum_ite ];
      rw [ show ( Finset.univ.filter fun x : Fin ( 2 * n ) => ( x : ℕ ) < i ) = Finset.univ.erase i from ?_, Finset.sum_erase_eq_sub ] <;> norm_num [ Fin.ext_iff ];
      grind;
    rw [ h_ci, Nat.cast_sub ] <;> norm_num [ h_cumulative_mass, hm.ne' ] ; ring; (
    rw [ mul_inv_cancel₀ ( by positivity ) ] ; rw [ show ( i : ℕ ) = 2 * n - 1 by omega ] ; ring;);
    unfold discrete_cum_global;
    -- Since the cumulative mass is the sum of the bin masses up to 2n-1, and the total integral of f is 1, the sum of all bin masses should be 1. Therefore, cumulative_mass f n (2 * n - 1) is at most 1.
    have h_cumulative_mass_le_one : cumulative_mass f n (2 * n - 1) ≤ 1 := by
      have h_cumulative_mass_le_one : ∑ j : Fin (2 * n), bin_masses f n j = 1 := by
        convert sum_bin_masses_eq_one n hn f ( show Function.support f ⊆ Set.Ioo ( -1 / 4 ) ( 1 / 4 ) from fun x hx => ⟨ by linarith [ hf_supp x hx ], by linarith [ hf_supp x hx ] ⟩ ) hf_int using 1;
      refine' h_cumulative_mass_le_one ▸ Finset.sum_le_sum fun j _ => _;
      split_ifs <;> norm_num [ bin_masses_nonneg n f hf_nonneg j ];
    rw [ ← Int.ofNat_le, Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr <| mul_nonneg ( show 0 ≤ cumulative_mass f n ( 2 * n - 1 ) from cumulative_mass_nonneg f n _ hf_nonneg ) <| Nat.cast_nonneg _ ) ] ; exact Int.le_of_lt_add_one <| Int.floor_lt.mpr <| by norm_num; nlinarith [ show ( m : ℝ ) ≥ 1 by norm_cast ] ;

lemma epsilon_error_bound (n m : ℕ) (hm : m > 0) (f : ℝ → ℝ) (i : ℕ)
    (hf_nonneg : ∀ x, 0 ≤ f x) :
    |epsilon_error f n m i| < 1 / m := by
  -- By definition of epsilon_error, we have |epsilon_error f n m i| = |(discrete_cum_global f n m i : ℝ) / m - cumulative_mass f n i|.
  have h_eps_def : |epsilon_error f n m i| = |(discrete_cum_global f n m i : ℝ) - cumulative_mass f n i * m| / m := by
    unfold epsilon_error;
    rw [ div_sub', abs_div, abs_of_nonneg ( by positivity : ( 0 : ℝ ) ≤ m ) ] ; ring_nf ; norm_num [ hm.ne' ] ;
  -- By definition of discrete_cum_global, we know that |(discrete_cum_global f n m i : ℝ) - cumulative_mass f n i * m| < 1.
  have h_discrete_cum_global : |(discrete_cum_global f n m i : ℝ) - cumulative_mass f n i * m| < 1 := by
    -- Apply the hypothesis that |(discrete_cum_global f n m i : ℝ) - cumulative_mass f n i * m| < 1.
    apply discrete_cum_error f n m i hf_nonneg;
  -- By combining the results from h_eps_def and h_discrete_cum_global, we can conclude the proof.
  rw [h_eps_def]
  exact div_lt_div_iff_of_pos_right (by positivity) |>.2 h_discrete_cum_global

lemma sum_c_sub_mu_eq (n m : ℕ) (hn : n > 0) (hm : m > 0) (f : ℝ → ℝ)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1)
    (hf_nonneg : ∀ x, 0 ≤ f x)
    (c : Fin (2 * n) → ℕ) (hc : canonical_discretization f n m = c)
    (a b : ℕ) (hab : a ≤ b) (hb : b < 2 * n) :
    ∑ j : Fin (2 * n), (if a ≤ j.1 ∧ j.1 ≤ b then (c j : ℝ) / m - bin_masses f n j else 0) =
      if b < 2 * n - 1 then
        epsilon_error f n m (b + 1) - epsilon_error f n m a
      else
        - epsilon_error f n m a := by
  have h_telescope : ∀ (i : Fin (2 * n)), (c i : ℝ) / m - bin_masses f n i = if i.1 < 2 * n - 1 then epsilon_error f n m (i.1 + 1) - epsilon_error f n m i.1 else -epsilon_error f n m i.1 := by
    exact?;
  have h_telescope_sum : ∀ (a b : ℕ) (hab : a ≤ b) (hb : b < 2 * n), ∑ i ∈ Finset.Icc a b, (if i < 2 * n - 1 then epsilon_error f n m (i + 1) - epsilon_error f n m i else -epsilon_error f n m i) = if b < 2 * n - 1 then epsilon_error f n m (b + 1) - epsilon_error f n m a else -epsilon_error f n m a := by
    intros a b hab hb
    induction' hab with b hb ih;
    · norm_num;
    · erw [ Finset.sum_Ico_succ_top ( by linarith [ Nat.succ_le_succ ‹a.le b› ] ), ih ( by linarith ) ];
      grind;
  convert h_telescope_sum a b hab hb using 1;
  rw [ ← Finset.sum_filter ];
  refine' Finset.sum_bij ( fun i hi => i ) _ _ _ _ <;> simp +decide [ Finset.mem_filter, Finset.mem_Icc ];
  · exact fun i hi₁ hi₂ j hj₁ hj₂ hij => Fin.ext hij;
  · exact fun x hx₁ hx₂ => ⟨ ⟨ x, by linarith ⟩, ⟨ hx₁, hx₂ ⟩, rfl ⟩;
  · exact fun i hi₁ hi₂ => h_telescope i

lemma sum_delta_bound (n m : ℕ) (hn : n > 0) (hm : m > 0) (f : ℝ → ℝ)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1)
    (hf_nonneg : ∀ x, 0 ≤ f x)
    (c : Fin (2 * n) → ℕ) (hc : canonical_discretization f n m = c)
    (a b : ℕ) (hab : a ≤ b) (hb : b < 2 * n) :
    |∑ j : Fin (2 * n), (if a ≤ j.1 ∧ j.1 ≤ b then (c j : ℝ) / m - bin_masses f n j else 0)| < 2 / m := by
  rw [ sum_c_sub_mu_eq ];
  any_goals assumption;
  split_ifs;
  · have h_eps_bound : ∀ k : ℕ, |epsilon_error f n m k| < 1 / m := by
      exact?;
    exact lt_of_le_of_lt ( abs_sub _ _ ) ( by convert add_lt_add ( h_eps_bound ( b + 1 ) ) ( h_eps_bound a ) using 1 ; ring );
  · simpa [ abs_neg ] using lt_of_lt_of_le ( epsilon_error_bound n m hm f a hf_nonneg ) ( by gcongr ; linarith )

lemma sum_delta_bound' (n m : ℕ) (hn : n > 0) (hm : m > 0) (f : ℝ → ℝ)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1)
    (hf_nonneg : ∀ x, 0 ≤ f x)
    (c : Fin (2 * n) → ℕ) (hc : canonical_discretization f n m = c)
    (a b : ℕ) (hab : a ≤ b) (hb : b < 2 * n) :
    |∑ j : Fin (2 * n), (if a ≤ j.1 ∧ j.1 ≤ b then (c j : ℝ) / m - bin_masses f n j else 0)| < 2 / m := by
  rw [ sum_c_sub_mu_eq ];
  any_goals assumption;
  split_ifs;
  · have h_eps_bound : ∀ k : ℕ, |epsilon_error f n m k| < 1 / m := by
      intro k; apply epsilon_error_bound n m hm f k hf_nonneg;
    exact lt_of_le_of_lt ( abs_sub _ _ ) ( by convert add_lt_add ( h_eps_bound ( b + 1 ) ) ( h_eps_bound a ) using 1 ; ring );
  · simpa [ abs_neg ] using lt_of_lt_of_le ( epsilon_error_bound n m hm f a hf_nonneg ) ( by gcongr ; linarith )

lemma sum_delta_bound_final (n m : ℕ) (hn : n > 0) (hm : m > 0) (f : ℝ → ℝ)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1)
    (hf_nonneg : ∀ x, 0 ≤ f x)
    (c : Fin (2 * n) → ℕ) (hc : canonical_discretization f n m = c)
    (a b : ℕ) (hab : a ≤ b) (hb : b < 2 * n) :
    |∑ j : Fin (2 * n), (if a ≤ j.1 ∧ j.1 ≤ b then (c j : ℝ) / m - bin_masses f n j else 0)| < 2 / m := by
  rw [sum_c_sub_mu_eq n m hn hm f hf_supp hf_int hf_nonneg c hc a b hab hb]
  split_ifs
  · have h1 : |epsilon_error f n m (b + 1)| < 1 / m := epsilon_error_bound n m hm f (b + 1) hf_nonneg
    have h2 : |epsilon_error f n m a| < 1 / m := epsilon_error_bound n m hm f a hf_nonneg
    calc |epsilon_error f n m (b + 1) - epsilon_error f n m a|
      _ ≤ |epsilon_error f n m (b + 1)| + |epsilon_error f n m a| := abs_sub _ _
      _ < 1 / m + 1 / m := add_lt_add h1 h2
      _ = 2 / m := by field_simp; ring
  · have h : |epsilon_error f n m a| < 1 / m := epsilon_error_bound n m hm f a hf_nonneg
    calc |-epsilon_error f n m a|
      _ = |epsilon_error f n m a| := abs_neg _
      _ < 1 / m := h
      _ < 2 / m := by
        rw [div_lt_div_iff_of_pos_right (Nat.cast_pos.mpr hm)]
        norm_num

noncomputable def delta_c (f : ℝ → ℝ) (n m : ℕ) (c : Fin (2 * n) → ℕ) (i : Fin (2 * n)) : ℝ :=
  (c i : ℝ) / m - bin_masses f n i

lemma test_value_expansion (n m : ℕ) (hn : n > 0) (hm : m > 0) (f : ℝ → ℝ)
    (c : Fin (2 * n) → ℕ) (ℓ s_lo : ℕ) :
    test_value n m c ℓ s_lo =
      ideal_test_value f n ℓ s_lo +
      (1 / (4 * n * ℓ : ℝ)) * (
        ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
          ∑ i : Fin (2 * n), ∑ j : Fin (2 * n),
            if i.1 + j.1 = k then
              (4 * n : ℝ)^2 * (
                bin_masses f n i * delta_c f n m c j +
                delta_c f n m c i * bin_masses f n j +
                delta_c f n m c i * delta_c f n m c j
              )
            else 0
      ) := by
  unfold test_value ideal_test_value delta_c;
  -- By expanding the discrete_autoconvolution and simplifying, we can see that the sum of the discrete_autoconvolutions is equal to the ideal test value plus the sum of the other terms.
  have h_expand : ∀ k, discrete_autoconvolution (fun i => (4 * n : ℝ) / m * (c i : ℝ)) k = discrete_autoconvolution (fun i => (4 * n : ℝ) * bin_masses f n i) k + ∑ i : Fin (2 * n), ∑ j : Fin (2 * n), if i.1 + j.1 = k then (4 * n : ℝ) ^ 2 * ((bin_masses f n i) * ((c j : ℝ) / m - bin_masses f n j) + ((c i : ℝ) / m - bin_masses f n i) * bin_masses f n j + ((c i : ℝ) / m - bin_masses f n i) * ((c j : ℝ) / m - bin_masses f n j)) else 0 := by
    intro k; unfold discrete_autoconvolution; simp +decide [ Finset.sum_add_distrib, Finset.mul_sum _ _ _, Finset.sum_mul _ _ _, mul_assoc, mul_comm, mul_left_comm, sq ] ; ring;
    simpa only [ ← Finset.sum_add_distrib ] using Finset.sum_congr rfl fun i hi => Finset.sum_congr rfl fun j hj => by split_ifs <;> ring;
  simp +decide only [mul_assoc, h_expand, mul_add, Finset.sum_add_distrib]

lemma epsilon_nonpos (f : ℝ → ℝ) (n m : ℕ) (i : ℕ) (hf_nonneg : ∀ x, 0 ≤ f x) :
    epsilon_error f n m i ≤ 0 := by
      -- Since the floor function is less than or equal to the original number, we have:
      have h_floor_le : (discrete_cum_global f n m i : ℝ) / m ≤ cumulative_mass f n i := by
        -- By definition of discrete_cum_global, we have:
        have h_discrete_cum_global : (discrete_cum_global f n m i : ℝ) = ⌊cumulative_mass f n i * m⌋ := by
          -- By definition of discrete_cum_global, we have that discrete_cum_global f n m i is equal to the floor of cumulative_mass f n i multiplied by m.
          simp [discrete_cum_global];
          exact Int.floor_nonneg.mpr ( mul_nonneg ( cumulative_mass_nonneg f n i hf_nonneg ) ( Nat.cast_nonneg _ ) );
        by_cases hm : m = 0 <;> simp_all +decide [ div_le_iff₀ ];
        · exact?;
        · exact div_le_iff₀ ( by positivity ) |>.2 ( Int.floor_le _ );
      -- By definition of epsilon_error, we have:
      simp [epsilon_error, h_floor_le]

lemma W_bound (n m : ℕ) (hn : n > 0) (hm : m > 0) (f : ℝ → ℝ)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1)
    (hf_nonneg : ∀ x, 0 ≤ f x)
    (c : Fin (2 * n) → ℕ) (hc : canonical_discretization f n m = c)
    (ℓ s_lo : ℕ) (hℓ : 2 ≤ ℓ)
    (W : ℝ) (hW : W = (∑ i ∈ contributing_bins n ℓ s_lo, (c i : ℝ)) / m) :
    ∑ i ∈ contributing_bins n ℓ s_lo, bin_masses f n i ≤ W + 1 / m := by
  -- By Lemma~\ref{lem:contributing_bins_iff}, $i \in \text{contributing\_bins} \iff a \le i \le b$.
  set a := Nat.max 0 (s_lo - (2 * n - 1))
  set b := Nat.min (2 * n - 1) (s_lo + ℓ - 2) with hb_def
  have h_cont : contributing_bins n ℓ s_lo = Finset.filter (fun i => a ≤ i.val ∧ i.val ≤ b) Finset.univ := by
    ext i; simp [a, b];
    convert contributing_bins_iff n hn ℓ s_lo hℓ i using 1 ; aesop;
  -- Let's split into cases based on whether $a \leq b$.
  by_cases h_cases : a ≤ b;
  · -- By `sum_delta_bound_final`, we have $|W - \sum_{i=a}^{b} \mu_i| < 1/m$.
    have h_bound : |W - ∑ i ∈ Finset.univ.filter (fun i => a ≤ i.val ∧ i.val ≤ b), bin_masses f n i| < 1 / (m : ℝ) := by
      have h_bound : |∑ i ∈ Finset.univ.filter (fun i => a ≤ i.val ∧ i.val ≤ b), (c i : ℝ) / m - ∑ i ∈ Finset.univ.filter (fun i => a ≤ i.val ∧ i.val ≤ b), bin_masses f n i| < 1 / (m : ℝ) := by
        have h_bound : |∑ i ∈ Finset.univ.filter (fun i => a ≤ i.val ∧ i.val ≤ b), (c i : ℝ) / m - ∑ i ∈ Finset.univ.filter (fun i => a ≤ i.val ∧ i.val ≤ b), bin_masses f n i| ≤ |epsilon_error f n m (b + 1) - epsilon_error f n m a| := by
          have h_bound : ∑ i ∈ Finset.univ.filter (fun i => a ≤ i.val ∧ i.val ≤ b), (c i : ℝ) / m - ∑ i ∈ Finset.univ.filter (fun i => a ≤ i.val ∧ i.val ≤ b), bin_masses f n i = if b < 2 * n - 1 then epsilon_error f n m (b + 1) - epsilon_error f n m a else -epsilon_error f n m a := by
            convert sum_c_sub_mu_eq n m hn hm f hf_supp hf_int hf_nonneg c hc a b h_cases _ using 1;
            · simp +decide [ Finset.sum_ite, Finset.filter_congr ];
            · exact lt_of_le_of_lt ( Nat.min_le_left _ _ ) ( Nat.sub_lt ( by positivity ) ( by positivity ) );
          split_ifs at h_bound <;> simp +decide [ h_bound ];
          rw [ show epsilon_error f n m ( b + 1 ) = 0 from _ ] ; norm_num [ abs_neg ];
          unfold epsilon_error; norm_num [ show b = 2 * n - 1 from le_antisymm ( Nat.min_le_left _ _ ) ( not_lt.mp ‹_› ) ] ;
          rw [ show 2 * n - 1 + 1 = 2 * n from Nat.succ_pred_eq_of_pos ( Nat.mul_pos zero_lt_two hn ) ] ; norm_num [ cumulative_mass, discrete_cum_global ] ; ring;
          rw [ show ( ∑ x : Fin ( 2 * n ), bin_masses f n x ) = 1 by exact sum_bin_masses_eq_one n hn f hf_supp hf_int ] ; norm_num [ hm.ne' ];
        have h_bound : |epsilon_error f n m (b + 1)| < 1 / (m : ℝ) ∧ |epsilon_error f n m a| < 1 / (m : ℝ) := by
          exact ⟨ epsilon_error_bound n m hm f ( b + 1 ) hf_nonneg, epsilon_error_bound n m hm f a hf_nonneg ⟩;
        have h_bound : epsilon_error f n m (b + 1) ≤ 0 ∧ epsilon_error f n m a ≤ 0 := by
          exact ⟨ epsilon_nonpos f n m _ hf_nonneg, epsilon_nonpos f n m _ hf_nonneg ⟩;
        cases abs_cases ( epsilon_error f n m ( b + 1 ) - epsilon_error f n m a ) <;> cases abs_cases ( epsilon_error f n m ( b + 1 ) ) <;> cases abs_cases ( epsilon_error f n m a ) <;> linarith [ show ( 0 : ℝ ) ≤ 1 / m by positivity ] ;
      simp_all +decide [ Finset.sum_div _ _ _ ];
    rw [ h_cont ] ; linarith [ abs_lt.mp h_bound ] ;
  · rw [ h_cont, Finset.sum_eq_zero ];
    · exact add_nonneg ( hW.symm ▸ div_nonneg ( Finset.sum_nonneg fun _ _ => Nat.cast_nonneg _ ) ( Nat.cast_nonneg _ ) ) ( by positivity );
    · grind