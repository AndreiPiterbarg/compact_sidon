          unfold cumulative_mass; norm_num [ Finset.sum_ite ] ;
        · omega);
    -- Let's simplify the sum by separating the terms where $j.val < 2 * n - 1$ and $j.val = 2 * n - 1$.
    have h_sum_split : ∑ j : Fin (2 * n), (if a ≤ j.val ∧ j.val ≤ b then c j else 0) = ∑ j ∈ Finset.Ico a (2 * n - 1), (discrete_cum_global f n m (j + 1) - discrete_cum_global f n m j) + (if a ≤ 2 * n - 1 ∧ 2 * n - 1 ≤ b then m - discrete_cum_global f n m (2 * n - 1) else 0) := by
      have h_sum_split : ∑ j : Fin (2 * n), (if a ≤ j.val ∧ j.val ≤ b then c j else 0) = ∑ j ∈ Finset.filter (fun j => a ≤ j ∧ j < 2 * n - 1) (Finset.range (2 * n)), (discrete_cum_global f n m (j + 1) - discrete_cum_global f n m j) + ∑ j ∈ Finset.filter (fun j => a ≤ j ∧ j = 2 * n - 1) (Finset.range (2 * n)), (m - discrete_cum_global f n m (2 * n - 1)) := by
