        · exact fun h => absurd ( h hn ) ( by omega );
    -- The sum of differences telescopes to $D(2n-1) - D(a)$.
    have h_telescope : ∑ j ∈ Finset.Ico a (2 * n - 1), (discrete_cum_global f n m (j + 1) - discrete_cum_global f n m j) = discrete_cum_global f n m (2 * n - 1) - discrete_cum_global f n m a := by
      have h_telescope : ∀ {a b : ℕ}, a ≤ b → b < 2 * n → ∑ j ∈ Finset.Ico a b, (discrete_cum_global f n m (j + 1) - discrete_cum_global f n m j) = discrete_cum_global f n m b - discrete_cum_global f n m a := by
        intros a b hab hb; induction hab <;> simp_all +decide [ Finset.sum_Ico_succ_top ] ;
        rename_i k hk₁ hk₂;
        rw [ hk₂ ( by linarith ), tsub_add_eq_add_tsub ];
        · rw [ Nat.add_sub_of_le ];
          unfold discrete_cum_global;
          rw [ ← Int.ofNat_le, Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr <| mul_nonneg ( cumulative_mass_nonneg f n _ hf_nonneg ) <| Nat.cast_nonneg _ ), Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr <| mul_nonneg ( cumulative_mass_nonneg f n _ hf_nonneg ) <| Nat.cast_nonneg _ ) ];
          gcongr;
          unfold cumulative_mass; simp +decide [ Finset.sum_ite ] ;
          exact Finset.sum_le_sum_of_subset_of_nonneg ( fun x hx => by exact Finset.mem_filter.mpr ⟨ Finset.mem_univ _, by linarith [ Finset.mem_filter.mp hx ] ⟩ ) fun _ _ _ => bin_masses_nonneg n f hf_nonneg _;
        · unfold discrete_cum_global;
          rw [ ← Int.ofNat_le, Int.natAbs_of_nonneg <| Int.floor_nonneg.mpr <| mul_nonneg ( cumulative_mass_nonneg f n a hf_nonneg ) <| Nat.cast_nonneg _, Int.natAbs_of_nonneg <| Int.floor_nonneg.mpr <| mul_nonneg ( cumulative_mass_nonneg f n _ hf_nonneg ) <| Nat.cast_nonneg _ ];
