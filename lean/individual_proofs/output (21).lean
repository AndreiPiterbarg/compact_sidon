    have h_c_def : ∀ j : Fin (2 * n), c j = if j.val < 2 * n - 1 then discrete_cum_global f n m (j.val + 1) - discrete_cum_global f n m j.val else m - discrete_cum_global f n m (2 * n - 1) := by
      intro j; exact (by
      rw [ ← hc ];
      split_ifs <;> simp +decide [ *, canonical_discretization ];
      · rw [ if_pos ( by omega ) ];
        rw [ show ( ∑ j : Fin ( 2 * n ), bin_masses f n j ) = 1 from ?_ ] ; norm_num [ discrete_cum_global ];
        · unfold cumulative_mass; aesop;
        · exact?;
