        intros k l hkl
        unfold discrete_cum_global;
        rw [ ← Int.ofNat_le, Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr <| mul_nonneg ( cumulative_mass_nonneg f n k hf_nonneg ) <| Nat.cast_nonneg _ ), Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr <| mul_nonneg ( cumulative_mass_nonneg f n l hf_nonneg ) <| Nat.cast_nonneg _ ) ];
