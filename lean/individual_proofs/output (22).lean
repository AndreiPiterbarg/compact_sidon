    rw [ abs_of_nonneg ( Int.cast_nonneg.mpr ( Int.floor_nonneg.mpr ( mul_nonneg ( Finset.sum_nonneg fun _ _ => ?_ ) ( Nat.cast_nonneg _ ) ) ) ) ] ; exact ⟨ Int.floor_le _, Int.lt_floor_add_one _ ⟩ ;
    exact MeasureTheory.integral_nonneg fun x => by rw [ Set.indicator_apply ] ; aesop;
  exact abs_le.mpr ⟨ by nlinarith [ show ( m : ℝ ) > 0 by positivity, div_mul_cancel₀ ( D_k : ℝ ) ( by positivity : ( m : ℝ ) ≠ 0 ), div_mul_cancel₀ ( 1 : ℝ ) ( by positivity : ( m : ℝ ) ≠ 0 ) ], by nlinarith [ show ( m : ℝ ) > 0 by positivity, div_mul_cancel₀ ( D_k : ℝ ) ( by positivity : ( m : ℝ ) ≠ 0 ), div_mul_cancel₀ ( 1 : ℝ ) ( by positivity : ( m : ℝ ) ≠ 0 ) ] ⟩

/-
The partial sum of the canonical discretization equals the discrete cumulative mass.
-/
lemma sum_canonical_discretization_eq (n m : ℕ) (hn : n > 0) (hm : m > 0)
    (f : ℝ → ℝ) (hf_nonneg : ∀ x, 0 ≤ f x)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1)
    (k : ℕ) (hk : k ≤ 2 * n) :
    ∑ i : Fin k, canonical_discretization f n m (Fin.castLE hk i) = discrete_cum_mass f n m k := by
  unfold canonical_discretization discrete_cum_mass;
  unfold target_cum_mass; induction' k with k ih <;> norm_num [ Fin.sum_univ_castSucc ] at *;
  split_ifs;
  · rw [ ih ( by linarith ), add_tsub_cancel_of_le ];
    rw [ ← Int.ofNat_le, Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr ?_ ), Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr ?_ ) ] <;> norm_num [ Finset.sum_ite ];
    · gcongr;
      · exact Finset.sum_nonneg fun _ _ => MeasureTheory.integral_nonneg fun _ => Set.indicator_nonneg ( fun _ _ => hf_nonneg _ ) _;
      · exact fun _ _ _ => MeasureTheory.integral_nonneg fun _ => Set.indicator_nonneg ( fun _ _ => hf_nonneg _ ) _;
      · exact fun x hx => Nat.lt_succ_of_lt hx;
    · refine' mul_nonneg ( div_nonneg _ _ ) ( Nat.cast_nonneg _ );
      · refine' Finset.sum_nonneg fun _ _ => _;
        exact MeasureTheory.integral_nonneg fun x => Set.indicator_nonneg ( fun _ _ => hf_nonneg x ) _;
      · exact Finset.sum_nonneg fun _ _ => MeasureTheory.integral_nonneg fun _ => Set.indicator_nonneg ( fun _ _ => hf_nonneg _ ) _;
    · refine' mul_nonneg ( div_nonneg _ _ ) ( Nat.cast_nonneg _ );
      · refine' Finset.sum_nonneg fun _ _ => _;
        exact MeasureTheory.integral_nonneg fun _ => Set.indicator_nonneg ( fun _ _ => hf_nonneg _ ) _;
      · exact Finset.sum_nonneg fun _ _ => MeasureTheory.integral_nonneg fun _ => Set.indicator_nonneg ( fun _ _ => hf_nonneg _ ) _;
  · rw [ ih ( by linarith ) ];
    rw [ add_tsub_cancel_of_le ];
    · rw [ show ( ∑ j : Fin ( 2 * n ), if ( j : ℕ ) < k + 1 then bin_masses f n j else 0 ) = ∑ j : Fin ( 2 * n ), bin_masses f n j from ?_ ];
      · rw [ sum_bin_masses_eq_one ] <;> norm_num [ hn, hm ];
        · exact hf_supp;
        · exact hf_int;
      · exact Finset.sum_congr rfl fun x hx => if_pos <| by linarith [ Fin.is_lt x ] ;
    · rw [ ← Int.ofNat_le, Int.natAbs_of_nonneg ( Int.floor_nonneg.mpr _ ) ];
      · refine' Int.le_of_lt_add_one ( Int.floor_lt.mpr _ );
        rw [ div_mul_eq_mul_div, div_lt_iff₀ ] <;> norm_cast;
        · norm_num [ Finset.sum_ite ];
          rw [ add_mul, one_mul, mul_comm ];
          refine' lt_add_of_le_of_pos ( mul_le_mul_of_nonneg_left ( Finset.sum_le_sum_of_subset_of_nonneg ( Finset.filter_subset _ _ ) fun _ _ _ => _ ) ( Nat.cast_nonneg _ ) ) ( _ );
          · exact MeasureTheory.integral_nonneg fun x => Set.indicator_nonneg ( fun _ _ => hf_nonneg x ) _;
          · rw [ sum_bin_masses_eq_one ] <;> norm_num [ hn, hm ];
            · exact hf_supp;
            · exact hf_int;
        · rw [ sum_bin_masses_eq_one ] <;> norm_num [ hn, hm ];
          · exact hf_supp;
          · exact hf_int;
      · refine' mul_nonneg ( div_nonneg _ _ ) ( Nat.cast_nonneg _ );
        · refine' Finset.sum_nonneg fun _ _ => _;
          split_ifs <;> norm_num [ bin_masses ];
          exact MeasureTheory.integral_nonneg fun x => by rw [ Set.indicator_apply ] ; split_ifs <;> norm_num ; exact hf_nonneg x;
        · exact Finset.sum_nonneg fun _ _ => MeasureTheory.integral_nonneg fun _ => Set.indicator_nonneg ( fun _ _ => hf_nonneg _ ) _

/-
Summation by parts bound (Abel's inequality variant).
-/
lemma sum_mul_bound_succ {n : ℕ} (a b : Fin (n + 1) → ℝ) (A V : ℝ)
    (ha : ∀ k : Fin (n + 1), |∑ i : Fin (n + 1), if i ≤ k then a i else 0| ≤ A)
    (hb : ∑ i : Fin n, |b (Fin.castSucc i) - b (Fin.succ i)| ≤ V)
    (hb_last : |b (Fin.last n)| ≤ V) :
    |∑ i : Fin (n + 1), a i * b i| ≤ A * (V + V) := by
  -- Applying the summation by parts formula, we have
  have h_sum_parts : ∑ i, (a i * b i) = ∑ i : Fin n, (∑ j ∈ Finset.univ.filter (fun j => j ≤ Fin.castSucc i), a j) * (b (Fin.castSucc i) - b (Fin.succ i)) + (∑ j ∈ Finset.univ.filter (fun j => j ≤ Fin.last n), a j) * b (Fin.last n) := by
    clear ha hb hb_last;
    induction' n with n ih;
    · simp +decide [ Fin.eq_zero ];
    · specialize ih ( fun i => a i.castSucc ) ( fun i => b i.castSucc ) ; simp_all +decide [ Fin.sum_univ_castSucc, Finset.sum_filter ] ; ring;
      simp +decide [ Fin.le_last, Finset.sum_ite ] ; ring!;
  -- Applying the triangle inequality to the sum, we get
  have h_triangle : |∑ i : Fin n, (∑ j ∈ Finset.univ.filter (fun j => j ≤ Fin.castSucc i), a j) * (b (Fin.castSucc i) - b (Fin.succ i))| ≤ A * (∑ i : Fin n, |b (Fin.castSucc i) - b (Fin.succ i)|) := by
    rw [ Finset.mul_sum _ _ _ ];
    refine' le_trans ( Finset.abs_sum_le_sum_abs _ _ ) ( Finset.sum_le_sum fun i _ => _ );
    simpa only [ abs_mul, Finset.sum_filter ] using mul_le_mul_of_nonneg_right ( ha _ ) ( abs_nonneg _ );
  rw [ h_sum_parts, abs_le ] at *;
  have := ha ( Fin.last n );
  norm_num [ Fin.le_last ] at * ; constructor <;> nlinarith [ abs_le.mp this ]

/-
The sum of the discretization error over any range is bounded by $1/m$.
-/
lemma sum_delta_bound_range (n m : ℕ) (hn : n > 0) (hm : m > 0)
    (f : ℝ → ℝ) (hf_nonneg : ∀ x, 0 ≤ f x)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1)
    (a b : ℕ) (h_le : a ≤ b) (hb : b ≤ 2 * n) :
    |∑ i ∈ (Finset.Ico a b).attach, delta f n m ⟨i.1, lt_of_lt_of_le (Finset.mem_Ico.mp i.2).2 hb⟩| ≤ 1 / m := by
  -- The sum over `Ico a b` is the difference of partial sums: $S_b - S_a$ by definition of `delta`.
  have h_diff_partial_sums : ∑ i ∈ Finset.attach (Finset.Ico a b), delta f n m ⟨i.val, by linarith [Finset.mem_Ico.mp i.2]⟩ = ∑ i : Fin b, delta f n m ⟨i, by linarith [Fin.is_lt i]⟩ - ∑ i : Fin a, delta f n m ⟨i, by linarith [Fin.is_lt i]⟩ := by
    rw [ eq_sub_iff_add_eq', ← Finset.sum_sdiff ( Finset.subset_univ ( Finset.image ( fun i : Fin a => ⟨ i, by linarith [ Fin.is_lt i ] ⟩ : Fin a → Fin b ) Finset.univ ) ) ];
    rw [ add_comm, Finset.sum_image ];
    · refine' congrArg₂ ( · + · ) _ _;
      · refine' Finset.sum_bij ( fun x hx => ⟨ x, by linarith [ Finset.mem_Ico.mp x.2 ] ⟩ ) _ _ _ _ <;> simp +decide;
        · exact fun x hx₁ hx₂ y hy => by linarith [ Fin.is_lt y ] ;
        · exact fun x hx => ⟨ x, ⟨ not_lt.mp fun contra => hx ⟨ x, contra ⟩ rfl, x.2 ⟩, rfl ⟩;
      · rfl;
    · exact fun i _ j _ hij => Fin.ext <| by simpa using congr_arg Fin.val hij;
  -- By the properties of the partial sums and the bound on the discretization error, we can conclude that the absolute value of the difference is bounded by $1/m$.
  have h_abs_diff_partial_sums : |∑ i : Fin b, delta f n m ⟨i, by linarith [Fin.is_lt i]⟩| ≤ 1 / m ∧ |∑ i : Fin a, delta f n m ⟨i, by linarith [Fin.is_lt i]⟩| ≤ 1 / m := by
    exact ⟨ by simpa using partial_sum_delta_bound n m hn hm f hf_nonneg hf_supp hf_int b hb, by simpa using partial_sum_delta_bound n m hn hm f hf_nonneg hf_supp hf_int a ( by linarith ) ⟩;
  rw [ h_diff_partial_sums, abs_le ] at *;
  -- By combining the inequalities from h_abs_diff_partial_sums, we can conclude the proof.
  apply And.intro;
  · have h_partial_sum_nonpos : ∑ i : Fin a, delta f n m ⟨i, by linarith [Fin.is_lt i]⟩ ≤ 0 := by
      have h_partial_sum_nonpos : ∑ i : Fin a, delta f n m ⟨i, by linarith [Fin.is_lt i]⟩ = (discrete_cum_mass f n m a : ℝ) / m - ∑ i : Fin a, bin_masses f n ⟨i, by linarith [Fin.is_lt i]⟩ := by
        have h_partial_sum_nonpos : ∑ i : Fin a, delta f n m ⟨i, by linarith [Fin.is_lt i]⟩ = (∑ i : Fin a, canonical_discretization f n m ⟨i, by linarith [Fin.is_lt i]⟩ : ℝ) / m - ∑ i : Fin a, bin_masses f n ⟨i, by linarith [Fin.is_lt i]⟩ := by
          unfold delta; simp +decide [ Finset.sum_div _ _ _ ] ;
        rw [ h_partial_sum_nonpos, ← sum_canonical_discretization_eq ];
        all_goals norm_cast;
        · exact hf_supp.trans ( by norm_num [ Rat.divInt_eq_div ] );
        · linarith;
      rw [ h_partial_sum_nonpos, div_sub', div_le_iff₀ ] <;> norm_cast;
      · norm_num [ discrete_cum_mass ];
        rw [ abs_of_nonneg ( Int.cast_nonneg.mpr ( Int.floor_nonneg.mpr _ ) ) ];
        · refine' le_trans ( Int.floor_le _ ) _;
          unfold target_cum_mass;
          rw [ mul_comm ];
          rw [ show ( ∑ j : Fin ( 2 * n ), if ( j : ℕ ) < a then bin_masses f n j else 0 ) = ∑ j : Fin a, bin_masses f n ⟨ j, by linarith [ Fin.is_lt j ] ⟩ from ?_ ];
          · rw [ sum_bin_masses_eq_one n hn f hf_supp hf_int ] ; norm_num;
          · rw [ ← Finset.sum_filter ];
            refine' Finset.sum_bij ( fun x hx => ⟨ x, by linarith [ Finset.mem_filter.mp hx, Fin.is_lt x ] ⟩ ) _ _ _ _ <;> simp +decide;
            · exact fun i hi j hj hij => Fin.ext hij;
            · exact fun i => ⟨ ⟨ i, by linarith [ Fin.is_lt i ] ⟩, by simp, rfl ⟩;
        · refine' mul_nonneg ( div_nonneg _ _ ) _ <;> norm_num;
          · refine' Finset.sum_nonneg fun i _ => _;
            split_ifs <;> norm_num [ bin_masses ];
            exact MeasureTheory.integral_nonneg fun x => by rw [ Set.indicator_apply ] ; aesop;
          · exact Finset.sum_nonneg fun _ _ => MeasureTheory.integral_nonneg fun _ => Set.indicator_nonneg ( fun _ _ => hf_nonneg _ ) _;
      · linarith;
    linarith [ abs_le.mp h_abs_diff_partial_sums.2 ];
  · have h_sum_delta_nonpos : ∀ k : Fin (2 * n + 1), ∑ i : Fin k, delta f n m (Fin.castLE (by linarith [Fin.is_lt k]) i) ≤ 0 := by
      intro k
      have h_sum_delta_nonpos : ∑ i : Fin k, delta f n m (Fin.castLE (by linarith [Fin.is_lt k]) i) = (discrete_cum_mass f n m k : ℝ) / m - ∑ i : Fin k, bin_masses f n (Fin.castLE (by linarith [Fin.is_lt k]) i) := by
        have h_sum_delta_nonpos : ∑ i : Fin k, delta f n m (Fin.castLE (by linarith [Fin.is_lt k]) i) = (∑ i : Fin k, (canonical_discretization f n m (Fin.castLE (by linarith [Fin.is_lt k]) i) : ℝ)) / m - ∑ i : Fin k, bin_masses f n (Fin.castLE (by linarith [Fin.is_lt k]) i) := by
          simp +decide [ delta, Finset.sum_div _ _ _ ];
        convert h_sum_delta_nonpos using 2;
        rw_mod_cast [ sum_canonical_discretization_eq ];
        · linarith;
        · linarith;
        · assumption;
        · convert hf_supp using 1 ; norm_num [ Rat.divInt_eq_div ];
        · exact hf_int;
      have h_sum_bin_masses : ∑ i : Fin k, bin_masses f n (Fin.castLE (by linarith [Fin.is_lt k]) i) = (target_cum_mass f n m k : ℝ) / m := by
        unfold target_cum_mass;
        field_simp;
        rw [ show ( ∑ j : Fin ( 2 * n ), if ( j : ℕ ) < k then bin_masses f n j else 0 ) = ∑ i : Fin k, bin_masses f n ( Fin.castLE ( by linarith [ Fin.is_lt k ] ) i ) from ?_, show ( ∑ j : Fin ( 2 * n ), bin_masses f n j ) = 1 from ?_ ];
        · ring;
        · exact?;
        · rw [ ← Finset.sum_filter ];
          refine' Finset.sum_bij ( fun i hi => ⟨ i, by linarith [ Fin.is_lt i, Fin.is_lt k, Finset.mem_filter.mp hi ] ⟩ ) _ _ _ _ <;> simp +decide [ Fin.ext_iff ];
          exact fun i => ⟨ ⟨ i, by linarith [ Fin.is_lt i, Fin.is_lt k ] ⟩, by simp, rfl ⟩;
      rw [ h_sum_delta_nonpos, h_sum_bin_masses ];
      rw [ sub_nonpos, div_le_div_iff_of_pos_right ] <;> norm_cast;
      unfold discrete_cum_mass; norm_num;
      rw [ abs_of_nonneg ( Int.cast_nonneg.mpr ( Int.floor_nonneg.mpr ( show 0 ≤ target_cum_mass f n m k from _ ) ) ) ] ; exact Int.floor_le _;
      refine' mul_nonneg ( div_nonneg _ _ ) _ <;> norm_num;
      · refine' Finset.sum_nonneg fun i _ => _ ; split_ifs <;> norm_num [ bin_masses ];
        exact MeasureTheory.integral_nonneg fun x => by rw [ Set.indicator_apply ] ; aesop;
      · exact Finset.sum_nonneg fun _ _ => MeasureTheory.integral_nonneg fun _ => Set.indicator_nonneg ( fun _ _ => hf_nonneg _ ) _;
    linarith! [ abs_le.mp h_abs_diff_partial_sums.2, h_sum_delta_nonpos ⟨ b, by linarith ⟩, h_sum_delta_nonpos ⟨ a, by linarith ⟩ ]

/-
The sum of absolute discretization errors is bounded by $2n/m$.
-/
lemma sum_abs_delta_le (n m : ℕ) (hn : n > 0) (hm : m > 0)
    (f : ℝ → ℝ) (hf_nonneg : ∀ x, 0 ≤ f x)
    (hf_supp : Function.support f ⊆ Set.Ioo (-1/4 : ℝ) (1/4))
    (hf_int : MeasureTheory.integral MeasureTheory.volume f = 1) :
    ∑ i : Fin (2 * n), |delta f n m i| ≤ (2 * n : ℝ) / m := by
  -- Apply the bound on the absolute value of the discretization error to each term in the sum.
  have h_sum_bound : ∑ i : Fin (2 * n), |delta f n m i| ≤ ∑ i : Fin (2 * n), (1 / m : ℝ) := by
    exact Finset.sum_le_sum fun i _ => by simpa using discretization_error_bound n m hn hm f hf_nonneg hf_supp hf_int i;
  simpa [ div_eq_mul_inv ] using h_sum_bound

/-
The maximum test value is attained at some parameters.
-/
lemma max_test_value_le_max (n m : ℕ) (hn : n > 0) (c : Fin (2 * n) → ℕ) :
    ∃ ℓ s_lo, ℓ ∈ Finset.Icc 2 (2 * (2 * n)) ∧ s_lo ∈ Finset.range (2 * (2 * n)) ∧
    max_test_value n m c = test_value n m c ℓ s_lo := by
  unfold max_test_value;
  simp +zetaDelta at *;
  split_ifs with h;
  · have := Finset.max'_mem ( Finset.biUnion ( Finset.Icc 2 ( 2 * ( 2 * n ) ) ) fun ℓ => Finset.image ( fun s_lo => test_value n m c ℓ s_lo ) ( Finset.range ( 2 * ( 2 * n ) ) ) ) ; aesop;
  · exact False.elim <| h ⟨ ⟨ 2, by norm_num, by linarith ⟩, hn.ne' ⟩

/-
The first error term in the decomposition of the test value difference.
-/
noncomputable def error_term_1 (n m : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) : ℝ :=
  let d := 2 * n
  let w := fun i => (canonical_discretization f n m i : ℝ) / m
  let mu := bin_masses f n
  let delta := fun i => w i - mu i
  (4 * n / ℓ) * ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
    ∑ i : Fin d,
      if h : i.1 ≤ k ∧ k - i.1 < d then
        delta i * mu ⟨k - i.1, h.2⟩
      else 0

/-
The second error term in the decomposition of the test value difference.
-/
noncomputable def error_term_2 (n m : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) : ℝ :=
  let d := 2 * n
  let w := fun i => (canonical_discretization f n m i : ℝ) / m
  let mu := bin_masses f n
  let delta := fun i => w i - mu i
  (4 * n / ℓ) * ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
    ∑ i : Fin d,
      if h : i.1 ≤ k ∧ k - i.1 < d then
        mu i * delta ⟨k - i.1, h.2⟩
      else 0

/-
The third error term in the decomposition of the test value difference.
-/
noncomputable def error_term_3 (n m : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) : ℝ :=
  let d := 2 * n
  let w := fun i => (canonical_discretization f n m i : ℝ) / m
  let mu := bin_masses f n
  let delta := fun i => w i - mu i
  (4 * n / ℓ) * ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
    ∑ i : Fin d,
      if h : i.1 ≤ k ∧ k - i.1 < d then
        delta i * delta ⟨k - i.1, h.2⟩
      else 0

/-
The mass of the function f in a window of length ℓ shifted by i.
-/
noncomputable def window_mass (n : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) (i : Fin (2 * n)) : ℝ :=
  ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
    if h : i.1 ≤ k ∧ k - i.1 < 2 * n then
      bin_masses f n ⟨k - i.1, h.2⟩
    else 0

/-
Extended bin masses function that returns 0 for out-of-bounds indices.
-/
noncomputable def extended_bin_masses (n : ℕ) (f : ℝ → ℝ) (k : ℤ) : ℝ :=
  if h : 0 ≤ k ∧ k < 2 * n then bin_masses f n ⟨k.natAbs, by
    linarith [ abs_of_nonneg h.1 ]⟩ else 0