theorem support_convolution_subset_add {f : ℝ → ℝ} {s : Set ℝ} (hf : Function.support f ⊆ s) :
    Function.support (MeasureTheory.convolution f f (ContinuousLinearMap.mul ℝ ℝ) MeasureTheory.volume) ⊆ s + s := by
  intro x hx
