/-- Discretization error: δ_i = c_i/m - μ_i. -/
noncomputable def delta (f : ℝ → ℝ) (n m : ℕ) (i : Fin (2 * n)) : ℝ :=
  (canonical_discretization f n m i : ℝ) / m - bin_masses f n i

/-- Target cumulative mass (before flooring). -/
noncomputable def target_cum_mass (f : ℝ → ℝ) (n m : ℕ) (k : ℕ) : ℝ :=
  let masses := bin_masses f n
  let total_mass := ∑ j, masses j
  let cum_mass := ∑ j : Fin (2 * n), if j.1 < k then masses j else 0
  (cum_mass) / total_mass * m

/-- Discrete cumulative mass D(k) = ⌊target_cum_mass⌋. -/
noncomputable def discrete_cum_mass (f : ℝ → ℝ) (n m : ℕ) (k : ℕ) : ℕ :=
  ⌊target_cum_mass f n m k⌋.natAbs

/-- Test value computed from continuous bin masses (for comparison). -/
noncomputable def test_value_continuous (n : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) : ℝ :=
  let d := 2 * n
  let a : Fin d → ℝ := fun i => (4 * n : ℝ) * bin_masses f n i
  let conv := discrete_autoconvolution a
  let sum_conv := ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2), conv k
  (1 / (4 * n * ℓ : ℝ)) * sum_conv

/-- Error term 1: δ_i × μ_{k-i} cross terms. -/
noncomputable def error_term_1 (n m : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) : ℝ :=
  let d := 2 * n
  let w := fun i => (canonical_discretization f n m i : ℝ) / m
  let mu := bin_masses f n
  let delta := fun i => w i - mu i
  (4 * n / ℓ) * ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
    ∑ i : Fin d,
      if h : i.1 ≤ k ∧ k - i.1 < d then
        delta i * mu ⟨k - i.1, h.2⟩
      else 0

/-- Error term 2: μ_i × δ_{k-i} cross terms. -/
noncomputable def error_term_2 (n m : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) : ℝ :=
  let d := 2 * n
  let w := fun i => (canonical_discretization f n m i : ℝ) / m
  let mu := bin_masses f n
  let delta := fun i => w i - mu i
  (4 * n / ℓ) * ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
    ∑ i : Fin d,
      if h : i.1 ≤ k ∧ k - i.1 < d then
        mu i * delta ⟨k - i.1, h.2⟩
      else 0

/-- Error term 3: δ_i × δ_{k-i} quadratic terms. -/
noncomputable def error_term_3 (n m : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) : ℝ :=
  let d := 2 * n
  let w := fun i => (canonical_discretization f n m i : ℝ) / m
  let mu := bin_masses f n
  let delta := fun i => w i - mu i
  (4 * n / ℓ) * ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
    ∑ i : Fin d,
      if h : i.1 ≤ k ∧ k - i.1 < d then
        delta i * delta ⟨k - i.1, h.2⟩
      else 0

/-- Window mass: sum of bin masses contributing to window (ℓ, s_lo) via bin i. -/
noncomputable def window_mass (n : ℕ) (f : ℝ → ℝ) (ℓ s_lo : ℕ) (i : Fin (2 * n)) : ℝ :=
  ∑ k ∈ Finset.Icc s_lo (s_lo + ℓ - 2),
    if h : i.1 ≤ k ∧ k - i.1 < 2 * n then
      bin_masses f n ⟨k - i.1, h.2⟩
    else 0

/-- Extended bin masses: returns 0 for out-of-bounds indices. -/
noncomputable def extended_bin_masses (n : ℕ) (f : ℝ → ℝ) (k : ℤ) : ℝ :=
  if h : 0 ≤ k ∧ k < 2 * n then bin_masses f n ⟨k.natAbs, by
    linarith [ abs_of_nonneg h.1 ]⟩ else 0

