/-
Integral is bounded by essential supremum times measure (ENNReal version).
-/
lemma integral_le_essSup_mul_measure_ennreal {α : Type*} [MeasureTheory.MeasureSpace α]
    (f : α → ENNReal) (s : Set α) (h_meas : MeasurableSet s) :
