def discrete_convolution_real (n : ℕ) (μ : Fin (2 * n) → ℝ) (k : ℕ) : ℝ :=
  Finset.sum Finset.univ fun i => Finset.sum Finset.univ fun j => if i.1 + j.1 = k then μ i * μ j else 0

def test_value_final (n m : ℕ) (c : Fin (2 * n) → ℕ) (ℓ s_lo : ℕ) : ℝ :=
  (1 / (4 * n * ℓ : ℝ)) * Finset.sum (Finset.Icc s_lo (s_lo + ℓ - 2)) fun k => (discrete_convolution n c k : ℝ)

noncomputable def continuous_test_value_final (f : ℝ → ℝ) (n m ℓ s_lo : ℕ) : ℝ :=
  (m ^ 2 / (4 * n * ℓ : ℝ)) * ∫ x in Set.Icc (-0.5 + s_lo / (4 * n : ℝ)) (-0.5 + (s_lo + ℓ - 2) / (4 * n : ℝ)), (MeasureTheory.convolution f f (ContinuousLinearMap.lsmul ℝ ℝ) MeasureTheory.volume) x

