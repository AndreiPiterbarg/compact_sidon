/-
Characterization of contributing bins.
-/
def contributing_bins (n ℓ s_lo : ℕ) : Finset (Fin (2 * n)) :=
  Finset.univ.filter fun i => ∃ j : Fin (2 * n), s_lo ≤ (i : ℕ) + j ∧ (i : ℕ) + j ≤ s_lo + ℓ - 2

theorem contributing_bins_iff (n : ℕ) (hn : n > 0) (ℓ s_lo : ℕ)
    (hℓ : 2 ≤ ℓ) (i : Fin (2 * n)) :
    i ∈ contributing_bins n ℓ s_lo ↔
      Nat.max 0 (s_lo - (2 * n - 1)) ≤ i.1 ∧ i.1 ≤ Nat.min (2 * n - 1) (s_lo + ℓ - 2) := by
  unfold contributing_bins;
  constructor <;> intro h <;> simp_all +decide [ Fin.exists_iff ];
  · grind +ring;
  · exact ⟨ s_lo - i, by omega, by omega, by omega ⟩

/-
Discrete convolution of a composition c.
-/
def discrete_convolution (n : ℕ) (c : Fin (2 * n) → ℕ) (k : ℕ) : ℕ :=
  Finset.sum Finset.univ fun i => Finset.sum Finset.univ fun j => if i.1 + j.1 = k then c i * c j else 0

/-
Definition of test value.
-/
def test_value (n m : ℕ) (c : Fin (2 * n) → ℕ) (ℓ s_lo : ℕ) : ℝ :=
  (1 / (4 * n * ℓ : ℝ)) * Finset.sum (Finset.Icc s_lo (s_lo + ℓ - 2)) fun k => (discrete_convolution n c k : ℝ)

/-
Definition of bin mass.
-/
def bin_mass (f : ℝ → ℝ) (n : ℕ) (i : Fin (2 * n)) : ℝ :=
  ∫ x in Set.Ico (-1/4 + (i : ℝ) / (4 * n : ℝ)) (-1/4 + ((i : ℝ) + 1) / (4 * n : ℝ)), f x

/-
Definition of canonical discretization.
-/
def canonical_discretization (f : ℝ → ℝ) (n m : ℕ) : Fin (2 * n) → ℕ :=
  fun i => Nat.floor (m * bin_mass f n i)

/-
Definition of autoconvolution ratio.
-/
noncomputable def autoconvolution_ratio (f : ℝ → ℝ) : ℝ :=
  (MeasureTheory.eLpNorm (MeasureTheory.convolution f f (ContinuousLinearMap.lsmul ℝ ℝ) MeasureTheory.volume) ⊤ MeasureTheory.volume).toReal / (∫ x, f x) ^ 2

/-
Definition of continuous test value.
-/
noncomputable def continuous_test_value (f : ℝ → ℝ) (n ℓ s_lo : ℕ) : ℝ :=
  (4 * n / ℓ : ℝ) * ∫ x in Set.Icc (-0.5 + s_lo / (4 * n : ℝ)) (-0.5 + (s_lo + ℓ - 2) / (4 * n : ℝ)), (MeasureTheory.convolution f f (ContinuousLinearMap.lsmul ℝ ℝ) MeasureTheory.volume) x

