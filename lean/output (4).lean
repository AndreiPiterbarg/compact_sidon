/-
The number of choices for a bin $c_i$ with capacity $x_{cap}$ is $\min(c_i, x_{cap}) - \max(0, c_i - x_{cap}) + 1$, assuming $c_i \le 2 x_{cap}$.
-/
theorem per_bin_choices (c_i x_cap : ℕ) (h : c_i ≤ 2 * x_cap) :
    Finset.card (Finset.Icc (Nat.max 0 (c_i - x_cap)) (Nat.min c_i x_cap)) =
    Nat.min c_i x_cap - Nat.max 0 (c_i - x_cap) + 1 := by
  simp +zetaDelta at *;
  grind +ring

/-
If $\sum_{i=0}^{d-1} c_i = m$ (parent sums to $m$) and child is $(a_0, c_0-a_0, \ldots, a_{d-1}, c_{d-1}-a_{d-1})$ where $0 \leq a_i \leq c_i$, then $\sum_{j=0}^{2d-1} \text{child}_j = m$.
-/
theorem child_preserves_mass (d m : ℕ) (parent : Fin d → ℕ) (a : Fin d → ℕ)
    (hp : ∑ i, parent i = m) (ha : ∀ i, a i ≤ parent i)
    (child : Fin (2 * d) → ℕ)
    (hc_even : ∀ i : Fin d, child ⟨2 * i.1, by
      linarith [ Fin.is_lt i ]⟩ = a i)
    (hc_odd : ∀ i : Fin d, child ⟨2 * i.1 + 1, by
      linarith [ Fin.is_lt i ]⟩ = parent i - a i) :
    ∑ j, child j = m := by
  all_goals generalize_proofs at *;
  -- By definition of `child`, we can split the sum into sums over the even and odd indices.
  have h_split : ∑ j : Fin (2 * d), child j = ∑ i : Fin d, child ⟨2 * i, by
    exact?⟩ + ∑ i : Fin d, child ⟨2 * i + 1, by
    solve_by_elim⟩ := by
    have h_split : Finset.range (2 * d) = Finset.image (fun i => 2 * i) (Finset.range d) ∪ Finset.image (fun i => 2 * i + 1) (Finset.range d) := by
      ext i
      simp [Finset.mem_range, Finset.mem_image];
      exact ⟨ fun hi => by rcases Nat.even_or_odd' i with ⟨ k, rfl | rfl ⟩ <;> [ left; right ] <;> exact ⟨ k, by linarith, rfl ⟩, fun hi => by rcases hi with ( ⟨ k, hk, rfl ⟩ | ⟨ k, hk, rfl ⟩ ) <;> linarith ⟩;
    rw [ Finset.sum_fin_eq_sum_range ];
    rw [ h_split, Finset.sum_union ] <;> norm_num [ Finset.sum_range, Fin.cast_val_eq_self ];
    · exact Finset.sum_congr rfl fun i hi => by aesop;
    · norm_num [ Finset.disjoint_right ];
      intros; omega;
  generalize_proofs at *;
  simp_all +decide [ ← Finset.sum_add_distrib, Nat.sub_add_cancel ( ha _ ) ]

/-
Each parent bin's total mass is preserved in its two child bins.
-/
theorem child_bin_sum (d : ℕ) (parent : Fin d → ℕ) (a : Fin d → ℕ)
    (ha : ∀ i, a i ≤ parent i)
    (child : Fin (2 * d) → ℕ)
    (hc_even : ∀ i : Fin d, child ⟨2 * i.1, by
      grind⟩ = a i)
    (hc_odd : ∀ i : Fin d, child ⟨2 * i.1 + 1, by
      grind⟩ = parent i - a i)
    (i : Fin d) :
    child ⟨2 * i.1, by
      all_goals generalize_proofs at *;
      exact?⟩ + child ⟨2 * i.1 + 1, by
      all_goals generalize_proofs at *;
      solve_by_elim⟩ = parent i := by
  rw [ hc_even, hc_odd, add_tsub_cancel_of_le ( ha i ) ]